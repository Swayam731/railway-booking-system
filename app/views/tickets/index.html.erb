<style>
  body{
    background-color: lightblue;
  }
  .ticket{
    border: 2px solid grey;
  }
  </style>
<h1>Your Bookings</h1>
<% @tickets.each do |ticket|%>
  <%@train = Train.find(ticket.train_id)%>
  <%@passenger = Passenger.find_by(ticket_id: ticket.id)%>
  <table>
    <div class="ticket">
    <tr>
      <th>Train Details:</th>
    </tr>
    <tr>
      <th>Train Name </th>
      <td><%=@train.train_name%></td>
      <th>Train Number </th>
      <td><%=@train.train_number%></td>
      <th>Date</th>
      <td><%=ticket.date&.strftime('%d-%m-%y')%></td>
    </tr>
    
    <tr>
      <th>Class </th>
      <td><%=ticket.journey_class%></td>
      <th>From </th>
      <td><%=ticket.source%></td>
      <th>To</th>
      <td><%=ticket.destination%></td>
    </tr>
    <tr>
      <th>passenger Details:</th>
    </tr>
    <tr>
      <th>Name </th>
      <td><%=@passenger&.name%></td>
      <th>Age </th>
      <td><%=@passenger&.age%></td>
      <%if ticket.number_of_passenger==2%>
      <th>Name </th>
      <td><%=@passenger&.name2%></td>
      <th>Age </th>
      <td><%=@passenger&.age2%></td>
      <%end%>
      <th>Coach No.</th>
      <td><%=ticket&.coach_name%></td>
      <th>Seat No.</th>
      <td><%=ticket&.seat_number%></td>
    </tr>
    </div>
  </table>
<%end%>